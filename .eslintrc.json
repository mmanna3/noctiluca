{
    "env": {
        "browser": true,
        "es2021": true,
        "jest": false
    },
    "settings": {
        "import/resolver": {
            "typescript": {}
        }
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:react/jsx-runtime",
        "plugin:@typescript-eslint/recommended",
        "prettier"
    ],
    "overrides": [
        {
            "files": ["src/api/clients.ts"],
            "rules": {
                "spaced-comment": "off"
            }
        },
        {
            "files": ["src/pantallas/inicio.tsx"],
            "rules": {
                "no-restricted-imports": [
                    "error",
                    {
                        "patterns": [
                            {
                                "group": [
                                    "**/habitos/habit-tracker",
                                    "**/habitos/menu-habitos",
                                    "**/inicio/buscar-escritos",
                                    "**/objetivos/*"
                                ],
                                "message": "En Inicio usar React.lazy() para no inflar el bundle de arranque."
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": [
        "react", 
        "react-hooks", 
        "@typescript-eslint", 
        "prettier"
    ],
    "rules": {
        "indent": [
            "error",
            "tab"
        ],
        "linebreak-style": [
            "error",
            "unix"
        ],
        "quotes": [
            "error",
            "double"
        ],
        "semi": [
            "error",
            "always"
        ],
        "react/react-in-jsx-scope": "off",
        "camelcase": "error",
        "spaced-comment": "error",
        "no-duplicate-imports": "error"
    }
}
